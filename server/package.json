{
  "name": "syncora-api",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create syncora-db",
    "db:migrate:local": "wrangler d1 migrations apply syncora-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply syncora-db --remote",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "zod": "^3.24.0",
    "@hono/zod-validator": "^0.5.0",
    "bcryptjs": "^3.0.2"
  },
  "devDependencies": {
    "wrangler": "^4.0.0",
    "typescript": "^5.7.0",
    "@types/bcryptjs": "^3.0.0",
    "@cloudflare/workers-types": "^4.20250601.0"
  }
}
